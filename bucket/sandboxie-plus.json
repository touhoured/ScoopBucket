{
    "version": "1.17.5",
    "description": "Sandbox isolation software (plus variant)",
    "homepage": "https://sandboxie-plus.com/",
    "license": "GPL-3.0-or-later",
    "notes": [
        "If the uninstall/update prompts SbieDrv/SbieSvc is still running, click",
        "Sandbox > Maintenance > Uninstall All"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/sandboxie-plus/Sandboxie/releases/download/v1.17.5/Sandboxie-Plus-x64-v1.17.5.exe",
            "hash": "517ba8798154cc36dcb73969344479fff0a8666961d459cc9b143aa60fa1f241"
        },
        "arm64": {
            "url": "https://github.com/sandboxie-plus/Sandboxie/releases/download/v1.17.5/Sandboxie-Plus-ARM64-v1.17.5.exe",
            "hash": "4e795159867260943a5d0c832ea80045ba883a12383065f09237bbc9a782daea"
        }
    },
    "innosetup": true,
    "bin": [
        [
            "start.exe",
            "sandboxie-start"
        ]
    ],
    "persist": [
        "Sandbox",
        "Sandboxie.ini",
        "Sandboxie-Plus.ini"
    ],
    "shortcuts": [
        [
            "SandMan.exe",
            "Sandboxie-Plus"
        ],
        [
            "Start.exe",
            "Sandboxie Start Menu",
            "/box:__ask__ start_menu"
        ],
        [
            "Start.exe",
            "Run any program sandboxed",
            "/box:__ask__ run_dialog"
        ],
        [
            "Start.exe",
            "Run Web browser sandboxed",
            "default_browser"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/sandboxie-plus/Sandboxie/releases",
        "regex": "/releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/sandboxie-plus/Sandboxie/releases/download/v$version/Sandboxie-Plus-x64-v$version.exe"
            },
            "arm64": {
                "url": "https://github.com/sandboxie-plus/Sandboxie/releases/download/v$version/Sandboxie-Plus-ARM64-v$version.exe"
            }
        },
        "hash": {
            "url": "https://github.com/sandboxie-plus/Sandboxie/releases/download/v$version/sha256-checksums.txt"
        }
    }
}
