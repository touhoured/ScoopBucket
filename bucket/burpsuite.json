    "installer": {
        "script": [
            "$varfile = \"$dir\\installer.varfile\"",
            "@'",
            "sys.fileAssociation.extensions$StringArray=",
            "sys.fileAssociation.launchers$StringArray=",
            "sys.programGroupDisabled$Boolean=true",
            "'@ | Set-Content $varfile",
            "$escaped_dir = $dir.Replace('\\', '\\\\')",
            "Add-Content $varfile \"sys.installationDir=$escaped_dir\"",
            "Invoke-ExternalCommand \"$dir\\$fname\" -ArgumentList @('-q', '-console', '-overwrite', '-varfile', \"$varfile\")",
            "Remove-Item \"$varfile\"",
            "if (Get-Command java -ErrorAction SilentlyContinue) {",
            "    & java -version *> $null",
            "    if ($LASTEXITCODE -eq 0) {",
            "        Remove-Item \"$dir\\jre\" -Recurse -Force -ErrorAction SilentlyContinue",
            "    }",
            "}",
            "for ($i=1; $i -le 5; $i++) { Remove-Item \"$dir\\$fname\" -ErrorAction SilentlyContinue; if ($?) { break } else { Start-Sleep -Seconds 1 } }"
        ]
    },
    "uninstaller": {
        "file": "uninstall.exe",
        "args": [
            "-q",
            "-console"
        ]
    },
    "shortcuts": [
        [
            "burpsuite.exe",
            "Burp Suite"
        ]
    ],
